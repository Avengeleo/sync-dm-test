# 复制为 .env 并填写(.env 已被 gitignore)。一个文件管全部服务,按前缀区分。

# ── bi-admin(sync-bi-api,端口 8094)──
BI_BASE_URL=http://127.0.0.1:8094
BI_USERNAME=
BI_PASSWORD=
# 可选:托盘图标校验样本(服务器能访问到才有意义)
BI_TRAY_ICON_OK=
BI_TRAY_ICON_BAD=

# ── dm-api(sync-dm-api 网关)── 待补:填了才跑 dm-api 套件
DM_API_BASE_URL=http://127.0.0.1:8080
# dm-api 走用户 JWT,鉴权方式待接入时确定(登录换 token / 直接注入)
DM_API_TOKEN=

# ── 通用 ──
BI_HTTP_TIMEOUT=15
