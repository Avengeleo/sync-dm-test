# 复制为 .env 并填写(.env 已被 gitignore)。一个文件管全部服务,按前缀区分。

# ── bi-admin(sync-bi-api)──
# BASE_URL 填 API 网关域名(到 /admin 前那一截),不是前端站点。示例:https://api-http.ramon2025.com
BI_BASE_URL=https://api-http.ramon2025.com
# USERNAME=登录手机号(后台按 mobile 列查账号,不是显示名)
BI_USERNAME=
# PASSWORD=浏览器登录 payload 里的 password 值(前端已 MD5,填那串 32 位 MD5,不是明文)
BI_PASSWORD=
# 可选:托盘图标校验样本(服务器能访问到才有意义)
BI_TRAY_ICON_OK=
BI_TRAY_ICON_BAD=

# ── dm-api(sync-dm-api 网关)── 填齐才跑 dm-api 套件;三层鉴权(AES旁路+签名+token)
# 网关域名(到 scheme://host,不带 /api;APP 走 api-gateway 域名,H5 走 h5-gateway 域名)
DM_API_BASE_URL=
# 版本前缀:APP 用 /api/v2,H5 用 /api/h5
DM_API_PREFIX=/api/v2
# 签名用:sys_apps 表里一条 is_enabled=1 的 app_id 及其 app_secrect
#   查库: SELECT app_id, app_secrect FROM sys_apps WHERE is_enabled=1;
DM_API_APP_ID=
DM_API_APP_SECRET=
# AES 旁路值(Encversion 头=此值即跳过 body 加解密):从配置/运维取,或抓真实请求的 Encversion 头
DM_API_WIPS=
# 有效用户会话 token(live 抓:H5/APP devtools 里请求头 token 的值)
DM_API_TOKEN=
# 可选:部分接口要 Client-type(1=app/2=pc/3=web)
DM_API_CLIENT_TYPE=

# ── 通用 ──
BI_HTTP_TIMEOUT=15
